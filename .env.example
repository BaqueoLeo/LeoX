# IA - APIs
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

# WhatsApp
WHATSAPP_SERVICE_URL=http://localhost:3000
MY_WHATSAPP_NUMBER=+1234567890

# iCloud
ICLOUD_USERNAME=tu@icloud.com
ICLOUD_PASSWORD=app_specific_password

# Gmail
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Scheduler
MORNING_BRIEF_TIME=08:00
EVENT_REMINDER_MINUTES=15
SILENCE_CHECK_HOURS=6
COMMITMENT_SCAN_INTERVAL_HOURS=1
MEMORY_CONSOLIDATION_TIME=23:30

# Personalidad
LEOX_NAME=Leo
COMMITMENT_AUTO_CREATE_THRESHOLD=0.95
COMMITMENT_ASK_THRESHOLD=0.70

# AI
AI_TIMEOUT_SECONDS=15
EMBEDDING_MODEL=text-embedding-3-small

# ElevenLabs (notas de voz)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
USE_VOICE_FOR_MORNING=true
USE_VOICE_FOR_ALERTS=true

# Google Places + Directions (tiempo de viaje)
GOOGLE_PLACES_API_KEY=
HOME_ADDRESS=
TRAVEL_MODE=driving
TRAVEL_BUFFER_MINUTES=15

# Interfaz web (iPhone / Safari)
# Deja en blanco para acceso sin contraseña (no recomendado en producción)
WEB_SECRET=
